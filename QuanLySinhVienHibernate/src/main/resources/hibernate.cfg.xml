<?xml version="1.0" encoding="UTF-8"?>
<hibernate-configuration
        xmlns="http://www.hibernate.org/xsd/orm/cfg"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.hibernate.org/xsd/orm/cfg
            https://www.hibernate.org/xsd/orm/cfg/hibernate-configuration-6.0.xsd">

    <session-factory>

        <!-- JDBC -->
        <property name="hibernate.connection.driver_class">
            com.mysql.cj.jdbc.Driver
        </property>

        <property name="hibernate.connection.url">
            jdbc:mysql://localhost:3306/quanlysinhvien
        </property>

        <property name="hibernate.connection.username">
            root
        </property>

        <property name="hibernate.connection.password">
            12345678
        </property>

        <!-- Hibernate -->
        <property name="hibernate.dialect">
            org.hibernate.dialect.MySQLDialect
        </property>

        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Entity -->
        <mapping class="com.quynh.quanlysinhvienhibernate.entity.Student"/>

    </session-factory>
</hibernate-configuration>